// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])

  @@map("sessions")
}

model User {
  id                String      @id @default(cuid())
  name          String   @unique
  email             String   @unique
  password    String
  registrationDate  DateTime @default(now())
  farms             Farm[]
  selectedFarmId    String?
  
  // Required by NextAuth
  emailVerified     DateTime?  
  accounts          Account[]
  sessions          Session[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Farm {
  id        String      @id @default(cuid())
  name      String
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     FarmTask[]

  @@map("farms")
}

model Task {
  id              String       @id @default(cuid())
  name            String
  bundleId        String
  type            String       @default("other")  // foraging, farming, fishing, mining, animals, cooking, socializing, combat, other
  seasons         String       @default("year-round")
  seasonNote      String?
  bundle          Bundle      @relation(fields: [bundleId], references: [id])
  farmTasks       FarmTask[]  // Required by Prisma for the relation to work
  calendarEvents  CalendarEvent[]   @relation("TaskCalendarEvents")

  @@map("tasks")
}

model Room {
  id          String    @id @default(cuid())
  name        String
  bundles     Bundle[]

  @@map("rooms")
}

model Bundle {
  id            String   @id @default(cuid())
  name          String
  tasksRequired Int
  reward        String?
  roomId        String
  room          Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  tasks         Task[]

  @@map("bundles")
}

model FarmTask {
  id          String    @id @default(cuid())
  farm        Farm      @relation(fields: [farmId], references: [id], onDelete: Cascade)
  farmId      String
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  taskId      String
  completed   Boolean   @default(false)

  @@unique([farmId, taskId])
  @@map("farm_tasks")
}

model CalendarEvent {
  id            String    @id @default(cuid())
  date          String
  name          String
  description   String?
  type          String    @default("other")
  tasks         Task[]             @relation("TaskCalendarEvents")
}
